{
  "name": "trippy",
  "private": true,
  "version": "0.0.0",
  "description": "Mobile-first next-generation ACID-style DAW.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/principalforce/trippy.git"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @trippy/web dev",
    "build": "pnpm --filter @trippy/web build",
    "build:engine": "wasm-pack build crates/trippy-engine --target web --out-dir ../../apps/web/src/engine/pkg --release && node -e \"require('fs').rmSync('apps/web/src/engine/pkg/.gitignore',{force:true})\"",
    "build:engine:dev": "wasm-pack build crates/trippy-engine --target web --out-dir ../../apps/web/src/engine/pkg --dev && node -e \"require('fs').rmSync('apps/web/src/engine/pkg/.gitignore',{force:true})\"",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:rust": "cargo test --workspace",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --all",
    "fmt:rust:check": "cargo fmt --all -- --check",
    "icons": "node scripts/gen-icons.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
